  { ambito: "Corte d'Appello", voce: "PRIMA SEZIONE CIVILE", posizione: "Via Freguglia 1, 20122 Milano (MI). Piano 3° lato Freguglia.", email: "sez1.civile.ca.milano@giustizia.it", telefono: "02/54333351" },
  { ambito: "Corte d'Appello", voce: "SECONDA SEZIONE CIVILE", posizione: "Via San Barnaba (Milano). Piano 3. Stanza 96.", email: "sez2.civile.ca.milano@giustizia.it", telefono: "02/54333402; 02/54334216" },
