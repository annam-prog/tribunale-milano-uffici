];

const $ = (id) => document.getElementById(id);
const ambitoSel = $("ambito");
const voceSel = $("voce");
const q = $("q");
const posManuale = $("posManuale");
const result = $("result");
const status = $("status");
const countPill = $("countPill");

function uniq(arr){ return [...new Set(arr)].sort((a,b)=>a.localeCompare(b,'it')); }

function setStatus(msg, kind=""){
  status.textContent = msg || "";
  status.className = "small " + (kind ? kind : "");
}

function populateAmbiti(){
  const ambiti = uniq(DATA.map(d=>d.ambito));
  ambitoSel.innerHTML = "";
  for(const a of ambiti){
    const opt = document.createElement("option");
    opt.value = a; opt.textContent = a;
    ambitoSel.appendChild(opt);
  }
}

function filteredItems(){
  const amb = ambitoSel.value;
  const query = (q.value || "").trim().toLowerCase();
  let items = DATA.filter(d=>d.ambito===amb);
  if(query){
    items = items.filter(d =>
      d.voce.toLowerCase().includes(query) ||
      d.posizione.toLowerCase().includes(query) ||
      (d.email||'').toLowerCase().includes(query) ||
      (d.telefono||'').toLowerCase().includes(query)
    );
  }
  return items.sort((x,y)=>x.voce.localeCompare(y.voce,'it'));
}

function populateVoci(keepSelection=false){
  const items = filteredItems();
  const prev = voceSel.value;
  voceSel.innerHTML = "";
  for(const it of items){
    const opt = document.createElement("option");
    opt.value = it.voce;
    opt.textContent = it.voce;
    voceSel.appendChild(opt);
  }

  if(keepSelection && [...voceSel.options].some(o=>o.value===prev)){
    voceSel.value = prev;
  }

  if(items.length === 0){
    setStatus("Nessun risultato nell'ambito selezionato (prova a svuotare la ricerca).", "warn");
    showEmpty();
  } else {
    setStatus("");
    updateResult();
  }
}

function showEmpty(){
  posManuale.value = "";
  result.querySelector(".title").textContent = "—";
  result.querySelector(".pos").textContent = "Nessuna voce selezionata.";
  result.querySelector(".meta").textContent = "";
}

function updateResult(){
  const amb = ambitoSel.value;
  const voce = voceSel.value;
  const item = DATA.find(d => d.ambito===amb && d.voce===voce);
  if(!item){ showEmpty(); return; }

  const lines = [];
  if(item.posizione) lines.push(item.posizione);
  if(item.email) lines.push(`Email: ${item.email}`);
  if(item.telefono) lines.push(`Telefono: ${item.telefono}`);
  if(item.pec) lines.push(`PEC: ${item.pec}`);

  posManuale.value = lines.join("\n");

  result.querySelector(".title").textContent = item.voce;
  result.querySelector(".pos").textContent = item.posizione || "—";

  const metaBits = [`Ambito: ${item.ambito}`];
  if(item.email) metaBits.push(`Email: ${item.email}`);
  if(item.telefono) metaBits.push(`Tel: ${item.telefono}`);
  if(item.pec) metaBits.push(`PEC: ${item.pec}`);
  result.querySelector(".meta").textContent = metaBits.join(" • ");
}

function copyPos(){
  const txt = posManuale.value.trim();
  if(!txt){ setStatus("Niente da copiare (seleziona prima una voce).", "warn"); return; }
  navigator.clipboard.writeText(txt).then(()=>{
    setStatus("Posizione copiata negli appunti.", "ok");
    setTimeout(()=>setStatus(""), 1600);
  }).catch(()=>{
    try{
      posManuale.focus(); posManuale.select();
      document.execCommand("copy");
      setStatus("Posizione copiata (fallback).", "ok");
      setTimeout(()=>setStatus(""), 1600);
    }catch(e){
      setStatus("Copia non riuscita: seleziona manualmente il testo e copia.", "warn");
    }
  });
}

function resetAll(){
  q.value = "";
  populateVoci(false);
  setStatus("Reset effettuato.", "ok");
  setTimeout(()=>setStatus(""), 1200);
}

function init(){
  countPill.textContent = `${DATA.length} voci`;
  populateAmbiti();
  populateVoci(false);

  ambitoSel.addEventListener("change", ()=>{ q.value=""; populateVoci(false); });
  voceSel.addEventListener("change", updateResult);
  q.addEventListener("input", ()=>populateVoci(true));
  $("copyBtn").addEventListener("click", copyPos);
  $("resetBtn").addEventListener("click", resetAll);

  updateResult();
}
init();
</script>
</body>
</html>
